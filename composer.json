{
    "name": "mdt-star/nexus",
    "description": "Laravel 核心权限模块 - 提供功能权限控制、菜单管理、数据范围策略、动态配置等基础设施能力",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/auth": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "MdtStar\\Nexus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MdtStar\\Nexus\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MdtStar\\Nexus\\Providers\\NexusServiceProvider"
            ]
        },
        "nexus": {
            "permissions": [
                {
                    "tag": "system",
                    "children": [
                        "system:config",
                        "system:permission"
                    ]
                },
                {
                    "tag": "model-access",
                    "children": ["list", "create", "delete"]
                },
                {
                    "tag": "desktop",
                    "children": ["list", "create", "show", "update", "delete"]
                },
                {
                    "tag": "desktop-item",
                    "children": ["list", "create", "show", "update", "delete", "reorder"]
                },
                {
                    "tag": "user",
                    "children": ["list", "create", "show", "update", "delete"]
                },
                {
                    "tag": "role",
                    "children": ["list", "create", "show", "update", "delete"]
                },
                {
                    "tag": "permission",
                    "children": ["list", "create", "show", "update", "delete"]
                },
                {
                    "tag": "permissionable",
                    "children": ["list", "create", "delete"]
                },
                {
                    "tag": "package",
                    "children": ["list"]
                },
                {
                    "tag": "model-scope",
                    "children": ["list"]
                }
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
